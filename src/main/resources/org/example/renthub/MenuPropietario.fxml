<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.MenuPropietarioController"
            prefWidth="1200" prefHeight="800"
            stylesheets="@css/generales.css, @css/propietario.css">

    <!-- ─────────────────────────────────────────────── -->
    <!-- BARRA SUPERIOR                                  -->
    <!-- ─────────────────────────────────────────────── -->
    <top>
        <HBox spacing="15"
              alignment="CENTER_LEFT"
              style="-fx-background-color: #FFFFFF;">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Label text="🏠 Panel del Propietario"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Button text="Cerrar sesión"
                    onAction="#cerrarSesion"
                    styleClass="btn-secondary"/>
        </HBox>
    </top>


    <!-- ─────────────────────────────────────────────── -->
    <!-- CONTENIDO PRINCIPAL                             -->
    <!-- ─────────────────────────────────────────────── -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="30">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <Label text="Bienvenido, propietario"
                   style="-fx-font-size: 26px; -fx-font-weight: bold;"/>

            <!-- GRID DE OPCIONES -->
            <GridPane hgap="30" vgap="30" alignment="CENTER">

                <!-- MIS INMUEBLES -->
                <VBox spacing="10" alignment="CENTER"
                      onMouseClicked="#abrirMisInmuebles"
                      styleClass="menu-card"
                      GridPane.rowIndex="0" GridPane.columnIndex="0">

                    <Label text="🏘️" style="-fx-font-size: 50;"/>
                    <Label text="Mis inmuebles" styleClass="menu-title"/>
                </VBox>


                <!-- NUEVO INMUEBLE -->
                <VBox spacing="10" alignment="CENTER"
                      onMouseClicked="#crearInmueble"
                      styleClass="menu-card"
                      GridPane.rowIndex="0" GridPane.columnIndex="1">

                    <Label text="➕" style="-fx-font-size: 50;"/>
                    <Label text="Nuevo inmueble" styleClass="menu-title"/>
                </VBox>


                <!-- RESERVAS -->
                <VBox spacing="10" alignment="CENTER"
                      onMouseClicked="#verReservasInmuebles"
                      styleClass="menu-card"
                      GridPane.rowIndex="0" GridPane.columnIndex="2">

                    <Label text="📅" style="-fx-font-size: 50;"/>
                    <Label text="Reservas" styleClass="menu-title"/>
                </VBox>


                <!-- ESTADÍSTICAS -->
                <VBox spacing="10" alignment="CENTER"
                      onMouseClicked="#verEstadisticas"
                      styleClass="menu-card"
                      GridPane.rowIndex="1" GridPane.columnIndex="0">

                    <Label text="📊" style="-fx-font-size: 50;"/>
                    <Label text="Estadísticas" styleClass="menu-title"/>
                </VBox>


                <!-- MI PERFIL -->
                <VBox spacing="10" alignment="CENTER"
                      onMouseClicked="#abrirPerfil"
                      styleClass="menu-card"
                      GridPane.rowIndex="1" GridPane.columnIndex="1">

                    <Label text="👤" style="-fx-font-size: 50;"/>
                    <Label text="Mi perfil" styleClass="menu-title"/>
                </VBox>

            </GridPane>

        </VBox>
    </center>

</BorderPane>


