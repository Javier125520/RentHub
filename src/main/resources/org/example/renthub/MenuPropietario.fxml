<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.renthub.controller.MenuPropietarioController"
            stylesheets="@css/propietario.css"
            styleClass="root">

    <!-- HEADER -->
    <top>
        <HBox styleClass="header" spacing="15" alignment="CENTER_LEFT">
            <Label text="🏠" styleClass="logo-icon"/>
            <VBox>
                <Label text="RentHub" styleClass="logo"/>
                <Label text="Panel de Propietario" styleClass="subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="lblUsuario" styleClass="user-name"/>
            <Button text="Cerrar Sesión" styleClass="btn-outline" onAction="#onLogout"/>
        </HBox>
    </top>

    <!-- CONTENIDO -->
    <center>
        <VBox spacing="30" styleClass="content">

            <!-- TABS -->
            <HBox alignment="CENTER" spacing="15" styleClass="tabs">
                <Button fx:id="btnMisViviendas" text="🏠 Mis Viviendas" styleClass="tab-active" onAction="#verMisViviendas"/>
                <Button fx:id="btnServicios" text="🛠 Servicios" styleClass="tab" onAction="#verServicios"/>
                <Button fx:id="btnReservas" text="📅 Reservas" styleClass="tab" onAction="#verReservas"/>
                <Button fx:id="btnResenas" text="⭐ Reseñas" styleClass="tab" onAction="#verResenas"/>
            </HBox>

            <!-- AQUÍ SE CAMBIA EL CONTENIDO -->
            <StackPane fx:id="contenidoCentral"/>

        </VBox>
    </center>

</BorderPane>
