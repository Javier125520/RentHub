<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="950" styleClass="booking-card" stylesheets="@../css/huesped.css" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.renthub.controller.ReseñaCardController" >
    <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5">
            <Label fx:id="lblInmueble" text="Apartamento Moderno en el Centro" styleClass="property-title-large"/>
            <Label fx:id="lblUbicacion" text="📍 Madrid, España" styleClass="text-muted"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER" spacing="5">
            <Label text="⭐" style="-fx-font-size: 18; -fx-text-fill: #FBBF24;"/>
            <Label fx:id="lblPuntuacion" text="5" style="-fx-font-weight: bold; -fx-font-size: 18;"/>
        </HBox>
    </HBox>

    <VBox spacing="10">
        <VBox.margin><Insets top="20" bottom="20"/></VBox.margin>
        <Label fx:id="lblComentario" text="Excelente estancia, muy limpio y bien ubicado." wrapText="true" style="-fx-font-size: 14; -fx-text-fill: #374151;"/>
        <Label fx:id="lblFecha" text="23 de diciembre de 2025" styleClass="text-muted" style="-fx-font-size: 11;"/>
    </VBox>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Button fx:id="btnEditar" text="✏ Editar" styleClass="btn-outline"/>
        <Button fx:id="btnEliminar" text="🗑 Eliminar" styleClass="btn-danger"/>
    </HBox>
</VBox>
