<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.ReservarInmuebleController"
            prefWidth="1000" prefHeight="700"
            stylesheets="@../css/generales.css, @css/huesped.css">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT"
              styleClass="topbar">

            <Button text="← Volver"
                    onAction="#volver"
                    styleClass="btn-secondary"/>

            <Label text="Realizar Reserva" styleClass="title"/>
        </HBox>
    </top>

    <!-- CONTENIDO -->
    <center>
        <HBox spacing="30">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- FOTO + INFORMACIÓN -->
            <VBox spacing="20">

                <ImageView fx:id="imgInmueble"
                           fitWidth="380" fitHeight="250"
                           preserveRatio="false"
                           style="-fx-background-color: #E5E7E9; -fx-background-radius: 12;"/>

                <VBox spacing="5">
                    <Label fx:id="lblTitulo" styleClass="subtitle"/>
                    <Label fx:id="lblCiudad" style="-fx-text-fill: #7F8C8D;"/>
                    <Label fx:id="lblPrecioNoche"
                           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                </VBox>

            </VBox>


            <!-- FORMULARIO DE RESERVA -->
            <VBox spacing="25" styleClass="card" prefWidth="420">

                <Label text="Datos de la reserva" styleClass="subtitle"/>

                <VBox spacing="12">
                    <Label text="Fecha de entrada"/>
                    <DatePicker fx:id="dpEntrada"
                                promptText="Seleccione fecha"/>
                </VBox>

                <VBox spacing="12">
                    <Label text="Fecha de salida"/>
                    <DatePicker fx:id="dpSalida"
                                promptText="Seleccione fecha"/>
                </VBox>

                <VBox spacing="12">
                    <Label text="Noches totales"/>
                    <Label fx:id="lblNoches"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="12">
                    <Label text="Precio total"/>
                    <Label fx:id="lblPrecioTotal"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                </VBox>

                <Button text="Proceder al pago"
                        fx:id="btnPagar"
                        styleClass="btn-primary"
                        prefHeight="45"
                        onAction="#irAPago"/>

            </VBox>
        </HBox>
    </center>

</BorderPane>



