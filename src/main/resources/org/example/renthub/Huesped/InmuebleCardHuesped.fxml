<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="320" styleClass="property-card" stylesheets="@../css/huesped.css" xmlns:fx="http://javafx.com/fxml">
    <StackPane styleClass="image-container">
        <ImageView fx:id="imgVivienda" fitWidth="320" fitHeight="200" preserveRatio="false">
            <clip>
                <javafx.scene.shape.Rectangle width="320" height="200" arcWidth="30" arcHeight="30" />
            </clip>
        </ImageView>
    </StackPane>

    <VBox spacing="8">
        <padding>
            <Insets top="15" right="15" bottom="15" left="15"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="lblTitulo" styleClass="property-title" wrapText="true" HBox.hgrow="ALWAYS" maxWidth="200"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblPrecio" styleClass="price-tag"/>
        </HBox>

        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label text="📍" style="-fx-font-size: 12;"/>
            <Label fx:id="lblUbicacion" styleClass="property-location"/>
        </HBox>
    </VBox>
</VBox>
