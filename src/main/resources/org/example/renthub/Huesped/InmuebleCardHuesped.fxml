<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.InmuebleCardController"
            styleClass="card-inmueble"
            prefWidth="260" prefHeight="330">

    <children>
        <VBox spacing="10" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- Imagen del inmueble -->
            <ImageView fx:id="imagenInmueble"
                       fitHeight="150"
                       preserveRatio="false"
                       style="-fx-background-radius: 12;"
                       VBox.vgrow="NEVER"/>

            <!-- TÍTULO -->
            <Label fx:id="lblTitulo"
                   wrapText="true"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

            <!-- CIUDAD -->
            <Label fx:id="lblCiudad"
                   wrapText="true"
                   style="-fx-text-fill: #7F8C8D; -fx-font-size: 13px;"/>

            <!-- PRECIO -->
            <Label fx:id="lblPrecio"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1B4F72;"/>

            <!-- BOTÓN -->
            <Button text="Ver detalles"
                    styleClass="btn-primary"
                    prefHeight="35"
                    onAction="#verDetalles"/>
        </VBox>
    </children>

</AnchorPane>

