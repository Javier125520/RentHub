<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.ReservaCardController"
            prefHeight="240"
            prefWidth="1100"
            styleClass="card"
            style="-fx-padding: 20; -fx-background-radius: 12;">

    <!-- FOTO A LA IZQUIERDA -->
    <left>
        <ImageView fx:id="imgInmueble"
                   fitHeight="200" fitWidth="260"
                   preserveRatio="false"
                   style="-fx-background-radius: 12;"/>
    </left>

    <!-- DATOS DE RESERVA -->
    <center>
        <VBox spacing="10" style="-fx-padding: 0 20 0 20;">

            <!-- TITULO + CIUDAD -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label fx:id="lblTitulo" styleClass="subtitle"/>
                <Label fx:id="lblCiudad" style="-fx-text-fill: #7F8C8D;"/>
            </HBox>

            <!-- FECHAS -->
            <HBox spacing="10">
                <Label text="Entrada:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblEntrada"/>

                <Label text="Salida:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblSalida"/>
            </HBox>

            <!-- NOCHES -->
            <HBox spacing="10">
                <Label text="Noches:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblNoches"/>
            </HBox>

            <!-- PRECIOS -->
            <HBox spacing="10">
                <Label text="Precio/noche:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblPrecioNoche"/>

                <Label text="Total:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblPrecioTotal"
                       style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            </HBox>

            <!-- DIRECCIÓN -->
            <HBox spacing="10">
                <Label text="Dirección:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblDireccion" wrapText="true"/>
            </HBox>

            <!-- ESTADO -->
            <HBox spacing="10">
                <Label text="Estado:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblEstado"/>
            </HBox>

        </VBox>
    </center>


    <!-- BOTONES -->
    <right>
        <VBox spacing="15" alignment="CENTER_RIGHT">

            <!-- PAGAR -->
            <Button fx:id="btnPagar"
                    text="Pagar ahora"
                    prefWidth="150"
                    styleClass="btn-primary"
                    onAction="#pagarReserva"
                    visible="false"
                    managed="false"/>

            <!-- EDITAR -->
            <Button fx:id="btnEditar"
                    text="Editar reserva"
                    prefWidth="150"
                    styleClass="btn-secondary"
                    onAction="#editarReserva"
                    visible="false"
                    managed="false"/>

            <!-- ELIMINAR -->
            <Button fx:id="btnEliminar"
                    text="Eliminar reserva"
                    prefWidth="150"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white;"
                    onAction="#eliminarReserva"
                    visible="false"
                    managed="false"/>

        </VBox>
    </right>

</BorderPane>
