<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="950" styleClass="booking-card" stylesheets="@../css/huesped.css" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.renthub.controller.ReservaCardController">
    <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5">
            <Label fx:id="lblTitulo" text="Nombre de la Vivienda" styleClass="property-title-large"/>
            <Label fx:id="lblUbicacion" text="📍 Ubicación" styleClass="text-muted"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblEstadoBadge" text="Estado" styleClass="status-badge"/>
    </HBox>

    <Separator>
        <VBox.margin><Insets top="20" bottom="20"/></VBox.margin>
    </Separator>

    <HBox spacing="80">
        <VBox spacing="5">
            <Label text="Fecha de entrada" styleClass="info-label"/>
            <Label fx:id="lblFechaEntrada" text="--" styleClass="info-data"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Fecha de salida" styleClass="info-label"/>
            <Label fx:id="lblFechaSalida" text="--" styleClass="info-data"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Precio total" styleClass="info-label"/>
            <Label fx:id="lblPrecioTotal" text="€0" styleClass="info-data-price"/>
        </VBox>
    </HBox>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <VBox.margin><Insets top="25"/></VBox.margin>

        <Button fx:id="btnAccionPrincipal" text="Acción" styleClass="btn-main-dark"/>

        <Button fx:id="btnEditar" text="✏ Editar" styleClass="btn-outline"/>
        <Button fx:id="btnCancelar" text="🗑 Cancelar" styleClass="btn-danger"/>
    </HBox>
</VBox>