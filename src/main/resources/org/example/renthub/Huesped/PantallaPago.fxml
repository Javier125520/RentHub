<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.PagoController"
            prefWidth="1000" prefHeight="700"
            stylesheets="@../css/generales.css, @../css/huesped.css">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="topbar">

            <Button text="← Volver"
                    onAction="#volver"
                    styleClass="btn-secondary"/>

            <Label text="Finalizar Pago" styleClass="title"/>
        </HBox>
    </top>


    <!-- CONTENIDO PRINCIPAL -->
    <center>
        <HBox spacing="40">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <!-- RESUMEN DE RESERVA -->
            <VBox spacing="20" styleClass="card" prefWidth="380">

                <Label text="Resumen de la Reserva" styleClass="subtitle"/>

                <Label fx:id="lblInmueble" wrapText="true"/>
                <Label fx:id="lblCiudad" style="-fx-text-fill: #7F8C8D;"/>

                <Separator/>

                <HBox spacing="10">
                    <Label text="Entrada:"/>
                    <Label fx:id="lblEntrada"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="Salida:"/>
                    <Label fx:id="lblSalida"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="Noches:"/>
                    <Label fx:id="lblNoches"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="Precio total:"/>
                    <Label fx:id="lblPrecioTotal"
                           style="-fx-font-weight: bold;"/>
                </HBox>

            </VBox>



            <!-- FORMULARIO DE PAGO -->
            <VBox spacing="25" styleClass="card" prefWidth="420">

                <Label text="Datos de Pago" styleClass="subtitle"/>

                <VBox spacing="10">
                    <Label text="Nombre del titular"/>
                    <TextField fx:id="txtTitular"
                               promptText="Ej: Javier Guerrero"
                               styleClass="text-input"/>
                </VBox>

                <VBox spacing="10">
                    <Label text="Número de tarjeta"/>
                    <TextField fx:id="txtNumeroTarjeta"
                               promptText="XXXX XXXX XXXX XXXX"
                               styleClass="text-input"/>
                </VBox>

                <HBox spacing="20">
                    <VBox spacing="10">
                        <Label text="Mes"/>
                        <TextField fx:id="txtMes"
                                   promptText="MM"
                                   styleClass="text-input"/>
                    </VBox>

                    <VBox spacing="10">
                        <Label text="Año"/>
                        <TextField fx:id="txtAnio"
                                   promptText="YY"
                                   styleClass="text-input"/>
                    </VBox>

                    <VBox spacing="10">
                        <Label text="CVV"/>
                        <TextField fx:id="txtCvv"
                                   promptText="000"
                                   styleClass="text-input"/>
                    </VBox>
                </HBox>

                <!-- BOTÓN PAGAR -->
                <Button text="Confirmar Pago"
                        fx:id="btnConfirmarPago"
                        styleClass="btn-primary"
                        prefHeight="45"
                        onAction="#confirmarPago"/>

                <!-- MENSAJE DE ERROR -->
                <Label fx:id="lblError"
                       style="-fx-text-fill: #C0392B; -fx-font-size: 14px;"
                       visible="false" managed="false"/>

            </VBox>
        </HBox>
    </center>

</BorderPane>

