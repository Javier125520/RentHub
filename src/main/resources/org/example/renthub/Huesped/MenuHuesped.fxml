<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="800.0" prefWidth="1200.0" stylesheets="@../css/huesped.css"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="org.example.renthub.controller.MenuHuespedController">

    <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20">
        <Label text="🏠" style="-fx-font-size: 24; -fx-text-fill: #2563EB;"/>
        <VBox>
            <Label text="HomeRent" style="-fx-font-weight: bold; -fx-font-size: 18;"/>
            <Label text="Panel de Huésped" style="-fx-text-fill: #6B7280; -fx-font-size: 12;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label text="👤 Ana López" style="-fx-font-weight: bold;"/>
        <Button text="↪ Cerrar Sesión" style="-fx-background-color: transparent; -fx-border-color: #E5E7EB; -fx-border-radius: 5;"/>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
        <VBox spacing="30" alignment="TOP_CENTER">
            <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

            <HBox alignment="CENTER" maxWidth="600" styleClass="nav-container">
                <Button text="🏠 Viviendas" styleClass="nav-button, nav-button-active" />
                <Button text="📅 Mis Reservas" styleClass="nav-button" />
                <Button text="⭐ Mis Reseñas" styleClass="nav-button" />
            </HBox>

            <VBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Viviendas Disponibles" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                <Label text="Encuentra tu alojamiento perfecto" style="-fx-text-fill: #6B7280;"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField promptText="🔍 Buscar por nombre de vivienda..." HBox.hgrow="ALWAYS" styleClass="search-bar"/>
                    <Button text="⚙ Filtros" style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 5; -fx-padding: 10 20;"/>
                </HBox>
                <Label text="6 viviendas encontradas" style="-fx-text-fill: #6B7280; -fx-font-size: 12;"/>
            </VBox>

            <TilePane hgap="25" vgap="25" prefColumns="3" alignment="CENTER">
                <VBox prefWidth="350" styleClass="property-card">
                </VBox>
            </TilePane>
        </VBox>
    </ScrollPane>
</VBox>