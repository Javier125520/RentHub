<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<?import java.net.URL?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.InicioController">

    <stylesheets>
        <URL value="@css/styles.css"/>
    </stylesheets>

    <center>
        <VBox alignment="CENTER" spacing="25" prefWidth="900" prefHeight="600"
              styleClass="background">

            <Label text="StaySmart" styleClass="title-main"/>
            <Label text="La plataforma moderna para gestión de alojamientos" styleClass="subtitle"/>

            <!-- HBox centrado -->
            <HBox alignment="CENTER" spacing="20">
                <Button text="Iniciar Sesión" onAction="#irLogin" styleClass="btn-primary"/>
                <Button text="Registrarse" onAction="#irRegistro" styleClass="btn-secondary"/>
            </HBox>

        </VBox>
    </center>


</BorderPane>

