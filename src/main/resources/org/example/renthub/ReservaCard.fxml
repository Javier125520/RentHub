<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.ReservaCardController"
            prefWidth="1100" prefHeight="200"
            styleClass="card-inmueble">

    <children>

        <!-- Imagen del inmueble -->
        <ImageView fx:id="imgInmueble"
                   fitWidth="250" fitHeight="180"
                   layoutX="10" layoutY="10"
                   preserveRatio="false"
                   style="-fx-background-radius: 10;" />

        <!-- Información -->
        <VBox layoutX="270" layoutY="20" spacing="10">

            <Label fx:id="lblTitulo"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <Label fx:id="lblFechas"
                   style="-fx-text-fill: #636E72; -fx-font-size: 14px;"/>

            <Label fx:id="lblEstado"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

            <Label fx:id="lblPrecioTotal"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B4F72;" />

        </VBox>

        <!-- Botón Ver Detalles -->
        <Button text="Ver detalles"
                layoutX="900" layoutY="75"
                prefWidth="150"
                styleClass="btn-primary"
                onAction="#verDetalles"/>

    </children>

</AnchorPane>
