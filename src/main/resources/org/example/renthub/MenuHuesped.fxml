<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.FlowPane?>


<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.MenuHuespedController"
            prefWidth="1400" prefHeight="900"
            stylesheets="@css/generales.css, @css/huesped.css">

    <!-- TOP BAR -->
    <top>
        <VBox spacing="10">

            <HBox spacing="15"
                  styleClass="topbar"
                  alignment="CENTER_LEFT">

                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>

                <!-- BUSCAR -->
                <TextField fx:id="txtBuscar"
                           promptText="Buscar por título o ciudad"
                           styleClass="search-field"
                           HBox.hgrow="ALWAYS"/>

                <Button text="🔍"
                        styleClass="btn-primary"
                        onAction="#buscar"/>

                <Button fx:id="btnMostrarFiltros"
                        text="🧩 Filtros"
                        styleClass="btn-secondary"
                        onAction="#toggleFiltros"/>
            </HBox>

            <!-- FILTROS -->
            <VBox fx:id="panelFiltros"
                  visible="false"
                  managed="false"
                  spacing="20"
                  styleClass="card">

                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <GridPane hgap="20" vgap="15">

                    <Label text="Ciudad:"/>
                    <TextField fx:id="filtroCiudad" styleClass="text-input" GridPane.columnIndex="1"/>

                    <Label text="Capacidad:" GridPane.rowIndex="1"/>
                    <TextField fx:id="filtroCapacidad" styleClass="text-input"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Habitaciones:" GridPane.rowIndex="2"/>
                    <TextField fx:id="filtroHabitaciones" styleClass="text-input"
                               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Precio mínimo (€):" GridPane.rowIndex="3"/>
                    <TextField fx:id="filtroPrecioMin" styleClass="text-input"
                               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Precio máximo (€):" GridPane.rowIndex="4"/>
                    <TextField fx:id="filtroPrecioMax" styleClass="text-input"
                               GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <Label text="Servicios:" GridPane.rowIndex="5"/>
                    <FlowPane fx:id="contenedorServicios"
                              hgap="10" vgap="10"
                              GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                </GridPane>

                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button text="Limpiar" styleClass="btn-secondary" onAction="#limpiarFiltros"/>
                    <Button text="Aplicar filtros" styleClass="btn-primary" onAction="#aplicarFiltros"/>
                </HBox>

            </VBox>

        </VBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="20" styleClass="sidebar">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Menú Huésped" styleClass="title"/>

            <Button text="🏠 Inicio" styleClass="sidebar-button" onAction="#goInicio"/>
            <Button text="📅 Mis reservas" styleClass="sidebar-button" onAction="#goMisReservas"/>
            <Button text="⭐ Mis reseñas" styleClass="sidebar-button" onAction="#goMisResenas"/>
            <Button text="👤 Mi perfil" styleClass="sidebar-button" onAction="#goPerfil"/>
            <Button text="⛔ Cerrar sesión" styleClass="sidebar-button" onAction="#cerrarSesion"/>
        </VBox>
    </left>

    <!-- LISTA DE INMUEBLES -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="scroll-pane">
            <FlowPane fx:id="contenedorInmuebles"
                      hgap="30" vgap="30"
                      style="-fx-background-color: #FCFCFC;">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30"/>
                </padding>
            </FlowPane>
        </ScrollPane>
    </center>

</BorderPane>

