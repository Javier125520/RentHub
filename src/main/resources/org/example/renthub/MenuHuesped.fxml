<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.renthub.controller.MenuHuespedController"
            stylesheets="@css/huesped.css"
            styleClass="root">

    <!-- HEADER -->
    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="15">
            <Label text="🏠" styleClass="logo-icon"/>

            <VBox alignment="CENTER_LEFT">
                <Label text="RentHub" styleClass="logo"/>
                <Label text="Panel de Huésped" styleClass="subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="lblUsuario" styleClass="user-name"/>
            <Button text="Cerrar Sesión" styleClass="btn-outline" onAction="#onLogout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="25" styleClass="content" alignment="CENTER">

            <HBox spacing="15" alignment="CENTER" styleClass="tabs">
                <Button fx:id="btnViviendas" text="🏠 Viviendas" styleClass="tab-active" onAction="#verViviendas"/>
                <Button fx:id="btnMisReservas" text="📅 Mis Reservas" styleClass="tab" onAction="#verReservas"/>
                <Button fx:id="btnMisResenas" text="⭐ Mis Reseñas" styleClass="tab" onAction="#verReseñas"/>
            </HBox>

            <StackPane fx:id="contenidoCentral" styleClass="view-container"/>

        </VBox>
    </center>

</BorderPane>

