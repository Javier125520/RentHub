<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.geometry.Insets?>
<BorderPane fx:id="mainContainer" xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.MenuHuespedController"
            stylesheets="@css/generales.css, @css/huesped.css">

    <!-- ───────────────────────────────-->
    <!--  SIDEBAR IZQUIERDO             -->
    <!-- ───────────────────────────────-->
    <left>
        <VBox spacing="20" styleClass="sidebar">

            <Label text="RentHub"
                   style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" />

            <Button text="🏠  Inicio"
                    onAction="#mostrarInicio"
                    styleClass="sidebar-button"/>

            <Button text="📅  Mis Reservas"
                    onAction="#verMisReservas"
                    styleClass="sidebar-button"/>

            <Button text="⭐  Mis Reseñas"
                    onAction="#verMisResenas"
                    styleClass="sidebar-button"/>

            <Button text="👤  Mi Perfil"
                    onAction="#abrirPerfil"
                    styleClass="sidebar-button"/>

            <VBox VBox.vgrow="ALWAYS"/>

            <Button text="Cerrar Sesión"
                    onAction="#cerrarSesion"
                    style="-fx-background-color: #C0392B; -fx-text-fill: white; -fx-background-radius: 8;" />
        </VBox>
    </left>


    <!-- ───────────────────────────────-->
    <!--   BARRA SUPERIOR DE BÚSQUEDA   -->
    <!-- ───────────────────────────────-->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="topbar">

            <TextField fx:id="searchBar" promptText="Buscar por ciudad, dirección o título..."
                       styleClass="search-field"
                       HBox.hgrow="ALWAYS"/>

            <Button text="Buscar"
                    onAction="#buscarInmuebles"
                    styleClass="btn-primary"/>
        </HBox>
    </top>


    <!-- ───────────────────────────────-->
    <!--  CONTENIDO PRINCIPAL (CARDS)   -->
    <!-- ───────────────────────────────-->
    <center>
        <ScrollPane fitToWidth="true" fx:id="scrollContent">
            <VBox spacing="25">
                <padding>
                    <Insets top="25" right="25" bottom="25" left="25"/>
                </padding>
                <!-- Título principal -->
                <Label text="Recomendados para ti"
                       styleClass="title"/>

                <!-- GRID DE INMUEBLES -->
                <GridPane fx:id="gridInmuebles" hgap="20" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>
                </GridPane>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>

