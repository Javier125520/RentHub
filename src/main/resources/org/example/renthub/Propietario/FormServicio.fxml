<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.FormServicioController"
            stylesheets="@../css/generales.css, @../css/propietario.css"
            prefWidth="650" prefHeight="500"
            styleClass="card">

    <!-- ─────────────── TOP: TÍTULO ─────────────── -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 20;">
            <children>
                <Label fx:id="lblModo"
                       text="Nuevo Servicio"
                       styleClass="title"/>
            </children>
        </HBox>
    </top>


    <!-- ─────────────── CENTER: FORMULARIO ─────────────── -->
    <center>
        <VBox spacing="25" style="-fx-padding: 30;">

            <!-- Nombre -->
            <VBox spacing="5">
                <Label text="Nombre del servicio" styleClass="subtitle"/>
                <TextField fx:id="txtNombre" styleClass="text-input"/>
            </VBox>

            <!-- Precio -->
            <VBox spacing="5">
                <Label text="Precio adicional (€)" styleClass="subtitle"/>
                <TextField fx:id="txtPrecio" styleClass="text-input"/>
            </VBox>

            <!-- Descripción -->
            <VBox spacing="5">
                <Label text="Descripción" styleClass="subtitle"/>
                <TextArea fx:id="txtDescripcion"
                          prefRowCount="5"
                          wrapText="true"
                          styleClass="text-input"/>
            </VBox>

        </VBox>
    </center>


    <!-- ─────────────── BOTTOM: BOTONES ─────────────── -->
    <bottom>
        <HBox spacing="20" alignment="CENTER_RIGHT" style="-fx-padding: 20;">
            <children>

                <!-- Botón Cancelar -->
                <Button text="Cancelar"
                        styleClass="btn-secondary"
                        onAction="#cancelar"/>

                <!-- Botón Guardar -->
                <Button text="Guardar"
                        fx:id="btnGuardar"
                        styleClass="btn-primary"
                        onAction="#guardarServicio"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>
