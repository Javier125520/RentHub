<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.FormInmuebleController"
            prefWidth="720" prefHeight="600"
            styleClass="card">

    <!-- ─────────────── TOP: TÍTULO ─────────────── -->
    <top>
        <HBox spacing="10" style="-fx-padding: 20;">
            <children>
                <Label fx:id="lblModo"
                       text="Nuevo Inmueble"
                       styleClass="title"/>
            </children>
        </HBox>
    </top>

    <!-- ─────────────── CENTER: FORMULARIO ─────────────── -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-padding: 10;">
            <content>
                <VBox spacing="20" style="-fx-padding: 20;">

                    <!-- Título -->
                    <VBox spacing="5">
                        <Label text="Título" styleClass="subtitle"/>
                        <TextField fx:id="txtTitulo" styleClass="text-input"/>
                    </VBox>

                    <!-- Ciudad -->
                    <VBox spacing="5">
                        <Label text="Ciudad" styleClass="subtitle"/>
                        <TextField fx:id="txtCiudad" styleClass="text-input"/>
                    </VBox>

                    <!-- Dirección -->
                    <VBox spacing="5">
                        <Label text="Dirección" styleClass="subtitle"/>
                        <TextField fx:id="txtDireccion" styleClass="text-input"/>
                    </VBox>

                    <!-- Precio -->
                    <VBox spacing="5">
                        <Label text="Precio por noche (€)" styleClass="subtitle"/>
                        <TextField fx:id="txtPrecio" styleClass="text-input"/>
                    </VBox>

                    <!-- Capacidad -->
                    <VBox spacing="5">
                        <Label text="Capacidad (personas)" styleClass="subtitle"/>
                        <TextField fx:id="txtCapacidad" styleClass="text-input"/>
                    </VBox>

                    <!-- Habitaciones -->
                    <VBox spacing="5">
                        <Label text="Número de habitaciones" styleClass="subtitle"/>
                        <TextField fx:id="txtHabitaciones" styleClass="text-input"/>
                    </VBox>

                    <!-- Descripción -->
                    <VBox spacing="5">
                        <Label text="Descripción" styleClass="subtitle"/>
                        <TextArea fx:id="txtDescripcion"
                                  prefRowCount="5"
                                  wrapText="true"
                                  styleClass="text-input"/>
                    </VBox>

                    <!-- Imagen -->
                    <VBox spacing="5">
                        <Label text="Imagen del inmueble" styleClass="subtitle"/>
                        <HBox spacing="15">
                            <children>
                                <ImageView fx:id="imgPreview"
                                           fitWidth="200"
                                           fitHeight="150"
                                           preserveRatio="false"
                                           style="-fx-background-color: #ECECEC; -fx-background-radius: 10;"/>
                                <Button text="Seleccionar imagen"
                                        styleClass="btn-secondary"
                                        onAction="#seleccionarImagen"/>
                            </children>
                        </HBox>
                    </VBox>

                    <!-- Servicios -->
                    <VBox spacing="5">
                        <Label text="Servicios disponibles" styleClass="subtitle"/>
                        <FlowPane fx:id="contenedorServicios"
                                  hgap="10" vgap="10"
                                  style="-fx-padding: 10;"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- ─────────────── BOTTOM: BOTONES ─────────────── -->
    <bottom>
        <HBox spacing="20" alignment="CENTER_RIGHT" style="-fx-padding: 20;">
            <children>
                <Button text="Cancelar"
                        styleClass="btn-secondary"
                        onAction="#cancelar"/>

                <Button text="Guardar"
                        styleClass="btn-primary"
                        fx:id="btnGuardar"
                        onAction="#guardarInmueble"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>

