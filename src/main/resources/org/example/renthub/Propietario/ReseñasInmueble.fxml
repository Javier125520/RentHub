<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.ReseñasInmuebleController"
            prefWidth="800" prefHeight="600"
            styleClass="card">

    <!-- ─────────────── TOP: TÍTULO + VOLVER ─────────────── -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 20;">
            <children>

                <Button text="← Volver"
                        styleClass="btn-secondary"
                        onAction="#volver"/>

                <Label fx:id="lblTitulo"
                       text="Reseñas del Inmueble"
                       styleClass="title"/>

            </children>
        </HBox>
    </top>

    <!-- ─────────────── CENTER: LISTA DE RESEÑAS ─────────────── -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-padding: 20;"
                    hbarPolicy="NEVER">

            <content>
                <VBox spacing="20"
                      fx:id="contenedorResenas"
                      style="-fx-padding: 10;">
                </VBox>
            </content>

        </ScrollPane>
    </center>

    <!-- ─────────────── BOTTOM: MEDIA DE ESTRELLAS ─────────────── -->
    <bottom>
        <HBox alignment="CENTER" spacing="10" style="-fx-padding: 20;">
            <children>

                <Label text="Valoración media:" styleClass="subtitle"/>

                <Label fx:id="lblMedia"
                       text="0.0"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

                <HBox spacing="5" fx:id="contenedorEstrellasMedia">
                    <!-- Aquí se cargarán estrellas amarillas -->
                </HBox>

            </children>
        </HBox>
    </bottom>

</BorderPane>

