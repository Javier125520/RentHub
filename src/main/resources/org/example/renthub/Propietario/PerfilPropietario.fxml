<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.PerfilPropietarioController"
            stylesheets="@../css/generales.css, @../css/propietario.css"
            prefWidth="1100" prefHeight="850">

    <!-- ─────────────── TOP BAR ─────────────── -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="topbar" style="-fx-padding: 15 25;">
            <children>

                <Label text="Mi Perfil" styleClass="title"/>

            </children>
        </HBox>
    </top>


    <!-- ─────────────── CONTENIDO CENTRAL ─────────────── -->
    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-padding: 20;">

            <VBox spacing="40" alignment="TOP_CENTER"
                  style="-fx-padding: 30;"
                  prefWidth="900">

                <!-- ──────── SECCIÓN FOTO ──────── -->
                <VBox spacing="20" alignment="CENTER" styleClass="card" style="-fx-padding: 30; -fx-max-width: 500;">
                    <children>

                        <Label text="Foto de perfil" styleClass="subtitle"/>

                        <Circle fx:id="imgPerfil"
                                radius="60"
                                styleClass="circle"/>

                        <Button text="Cambiar foto"
                                styleClass="btn-secondary"
                                onAction="#cambiarFoto"/>
                    </children>
                </VBox>


                <!-- ──────── SECCIÓN DATOS PERSONALES ──────── -->
                <VBox spacing="25" alignment="CENTER" styleClass="card" style="-fx-padding: 30; -fx-max-width: 600;">

                    <Label text="Información personal" styleClass="subtitle"/>

                    <!-- Nombre -->
                    <VBox spacing="5" alignment="CENTER_LEFT" prefWidth="500">
                        <Label text="Nombre completo" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="txtNombre" styleClass="text-input"/>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="5" alignment="CENTER_LEFT" prefWidth="500">
                        <Label text="Correo electrónico" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="txtEmail" styleClass="text-input"/>
                    </VBox>

                    <!-- Teléfono -->
                    <VBox spacing="5" alignment="CENTER_LEFT" prefWidth="500">
                        <Label text="Teléfono de contacto" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="txtTelefono" styleClass="text-input"/>
                    </VBox>

                    <!-- Contraseña -->
                    <HBox spacing="15" alignment="CENTER_LEFT" prefWidth="500">
                        <Label text="Contraseña:" style="-fx-font-weight: bold;"/>
                        <Button text="Cambiar contraseña"
                                styleClass="btn-secondary"
                                onAction="#cambiarContrasena"/>
                    </HBox>

                    <!-- Guardar -->
                    <Button text="Guardar cambios"
                            fx:id="btnGuardar"
                            styleClass="btn-primary"
                            prefWidth="200"
                            onAction="#guardarCambios"/>

                </VBox>

            </VBox>

        </ScrollPane>
    </center>

</BorderPane>
