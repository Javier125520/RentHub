<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="950" styleClass="booking-card" stylesheets="@../css/propietario.css" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.renthub.controller.ReservaCardPropietarioController">
    <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5">
            <Label fx:id="lblInmueble" text="Apartamento Moderno en el Centro" styleClass="property-title-large"/>
            <Label fx:id="lblUbicacion" text="📍 Madrid, España" styleClass="text-muted"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblEstado" text="Pagada" styleClass="status-badge, paid-badge"/>
    </HBox>

    <HBox spacing="100" alignment="CENTER_LEFT">
        <VBox.margin><Insets top="20"/></VBox.margin>

        <VBox spacing="5">
            <Label text="Huésped" styleClass="info-label"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="👤" style="-fx-font-size: 14;"/>
                <VBox>
                    <Label fx:id="lblNombreHuesped" text="Ana López" styleClass="info-data"/>
                    <Label fx:id="lblCorreoHuesped" text="huesped1@test.com" styleClass="text-muted" style="-fx-font-size: 11;"/>
                </VBox>
            </HBox>
            <Label fx:id="lblFechaCreacion" text="Reserva creada el 26 de diciembre de 2025" styleClass="text-muted" style="-fx-font-size: 10;">
                <VBox.margin><Insets top="5"/></VBox.margin>
            </Label>
        </VBox>

        <VBox spacing="5">
            <Label text="Check-in" styleClass="info-label"/>
            <Label fx:id="lblCheckIn" text="27 dic 2025" styleClass="info-data"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Check-out" styleClass="info-label"/>
            <Label fx:id="lblCheckOut" text="31 dic 2025" styleClass="info-data"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Ingreso total" styleClass="info-label"/>
            <Label fx:id="lblIngreso" text="€340" styleClass="info-data-price"/>
        </VBox>
    </HBox>
</VBox>
