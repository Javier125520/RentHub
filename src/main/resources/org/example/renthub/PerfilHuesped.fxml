<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.renthub.controller.PerfilHuespedController"
            stylesheets="@css/huesped.css">

    <ScrollPane fitToWidth="true"
                AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <content>
            <StackPane>
                <VBox spacing="18" styleClass="modal-container" maxWidth="1000" minWidth="600" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <VBox spacing="4">
                        <Label text="Mi Perfil" styleClass="modal-title"/>
                        <Label text="Información de tu cuenta" styleClass="modal-subtitle"/>
                    </VBox>

                    <HBox spacing="16" alignment="TOP_CENTER">

                        <VBox spacing="12" styleClass="card" HBox.hgrow="ALWAYS">
                            <Label text="👤 Información Personal" styleClass="card-title"/>

                            <VBox spacing="6">
                                <Label text="Nombre" styleClass="info-label"/>
                                <Label fx:id="lblNombre" text="Javier Guerrero Hurtado" styleClass="info-value" wrapText="true"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Correo Electrónico" styleClass="info-label"/>
                                <Label fx:id="lblEmail" text="javier.guerrero07@gmail.com" styleClass="info-value" wrapText="true"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Tipo de Usuario" styleClass="info-label"/>
                                <Label text="Huésped" styleClass="info-value"/>
                            </VBox>
                        </VBox>

                        <VBox spacing="12" styleClass="card" HBox.hgrow="ALWAYS">
                            <Label text="⭐ Estadísticas" styleClass="card-title"/>

                            <GridPane hgap="12" vgap="12" alignment="CENTER">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50" />
                                    <ColumnConstraints percentWidth="50" />
                                </columnConstraints>

                                <VBox styleClass="stat-card stat-blue" alignment= "CENTER_LEFT" spacing="5">
                                    <Label text="Total Reservas" styleClass="stat-label" wrapText="true" textAlignment="CENTER"/>
                                    <Label fx:id="lblTotalReservas" text="1" styleClass="stat-value"/>
                                </VBox>

                                <VBox GridPane.columnIndex="1" styleClass="stat-card stat-green" alignment="CENTER_LEFT" spacing="5">
                                    <Label text="Reservas Pagadas" styleClass="stat-label" wrapText="true" textAlignment="CENTER"/>
                                    <Label fx:id="lblPagadas" text="0" styleClass="stat-value"/>
                                </VBox>

                                <VBox GridPane.rowIndex="1" styleClass="stat-card stat-yellow" alignment="CENTER_LEFT" spacing="5">
                                    <Label text="Pendientes" styleClass="stat-label" wrapText="true" textAlignment="CENTER"/>
                                    <Label fx:id="lblPendientes" text="0" styleClass="stat-value"/>
                                </VBox>

                                <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="stat-card stat-purple" alignment="CENTER_LEFT" spacing="5">
                                    <Label text="Reseñas" styleClass="stat-label" wrapText="true" textAlignment="CENTER"/>
                                    <Label fx:id="lblResenas" text="0" styleClass="stat-value"/>
                                </VBox>
                            </GridPane>
                        </VBox>

                    </HBox>

                    <VBox spacing="10" styleClass="card">
                        <Label text="📅 Actividad Reciente" styleClass="card-title"/>
                        <Label fx:id="lblUltimaReserva" text="Última reserva: 7 de enero de 2026" styleClass="activity-text"/>
                    </VBox>

                    <VBox spacing="12" styleClass="card">
                        <Label text="⚙ Acciones de Cuenta" styleClass="card-title"/>
                        <HBox spacing="12">
                            <Button text="🚪 Cerrar Sesión" styleClass="btn-danger" onAction="#onCerrarSesion"/>
                            <Button text="🔒 Cambiar Contraseña" styleClass="btn-secondary" onAction="#onCambiarContrasena"/>
                        </HBox>
                    </VBox>
                </VBox>
            </StackPane>
        </content>
    </ScrollPane>
</AnchorPane>


