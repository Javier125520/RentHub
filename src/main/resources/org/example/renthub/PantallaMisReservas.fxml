<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.MisReservasController"
            prefWidth="1200" prefHeight="800"
            stylesheets="@css/generales.css, @css/huesped.css">

    <!-- ─────────────────────────────────────────────── -->
    <!-- BARRA SUPERIOR                                   -->
    <!-- ─────────────────────────────────────────────── -->
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #FFFFFF;">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Button text="⟵ Volver"
                    onAction="#volver"
                    styleClass="btn-secondary"/>

            <Label text="Mis Reservas"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
        </HBox>
    </top>


    <!-- ─────────────────────────────────────────────── -->
    <!-- CONTENIDO                                       -->
    <!-- ─────────────────────────────────────────────── -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="25">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <Label text="Reservas Realizadas"
                       styleClass="title"/>

                <!-- Aquí se cargarán las cards de reservas -->
                <VBox fx:id="contenedorReservas" spacing="20">
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>


