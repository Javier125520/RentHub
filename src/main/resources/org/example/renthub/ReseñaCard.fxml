<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.ReseñaCardController"
            prefWidth="1100" prefHeight="200"
            styleClass="card-inmueble">

    <children>

        <!-- Imagen del inmueble -->
        <ImageView fx:id="imgInmueble"
                   fitWidth="230" fitHeight="180"
                   layoutX="10" layoutY="10"
                   preserveRatio="false"
                   style="-fx-background-radius: 10;" />


        <!-- INFORMACIÓN DE LA RESEÑA -->
        <VBox layoutX="260" layoutY="10" spacing="10">

            <!-- Título del inmueble -->
            <Label fx:id="lblTituloInmueble"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <!-- Estrellas -->
            <HBox spacing="5" fx:id="estrellasHBox">
                <!-- Se llenan dinámicamente con estrellas -->
            </HBox>

            <!-- Comentario -->
            <Label fx:id="lblComentario"
                   wrapText="true"
                   style="-fx-text-fill: #636E72; -fx-font-size: 14px;"
                   maxWidth="500"/>

            <Label fx:id="lblFecha"
                   style="-fx-font-size: 13px; -fx-text-fill: #95A5A6;"/>

        </VBox>

        <!-- Botones laterales -->
        <VBox layoutX="900" layoutY="50" spacing="15">

            <Button text="Editar"
                    styleClass="btn-secondary"
                    onAction="#editarResena"
                    prefWidth="150"/>

            <Button text="Eliminar"
                    style="-fx-background-color: #C0392B; -fx-text-fill: white;"
                    onAction="#eliminarResena"
                    prefWidth="150"/>

        </VBox>

    </children>

</AnchorPane>

