<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.renthub.controller.ResenasViewController"
      spacing="25"
      styleClass="content">

    <VBox spacing="5">
        <Label text="Reseñas de Mis Viviendas" styleClass="title"/>
        <Label text="Opiniones de los huéspedes sobre tus propiedades" styleClass="description"/>
    </VBox>

    <HBox spacing="20" alignment="CENTER">
        <VBox styleClass="stat-card" alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS">
            <Label fx:id="lblPromedio" text="⭐ 4.0" styleClass="stat-value"/>
            <Label text="Calificación promedio" styleClass="stat-label"/>
        </VBox>

        <VBox styleClass="stat-card" alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTotalResenas" text="3" styleClass="stat-value"/>
            <Label text="Total de reseñas" styleClass="stat-label"/>
        </VBox>

        <VBox styleClass="stat-card" alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS">
            <Label fx:id="lblViviendas" text="1" styleClass="stat-value"/>
            <Label text="Viviendas con reseñas" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="scroll" VBox.vgrow="ALWAYS">
        <content>
            <StackPane alignment="TOP_CENTER">
                <VBox spacing="25" maxWidth="1000" HBox.hgrow="ALWAYS">
                    <VBox fx:id="contenedorReseñas" spacing="20" maxWidth="Infinity"/>
                </VBox>
            </StackPane>
        </content>
    </ScrollPane>
</VBox>