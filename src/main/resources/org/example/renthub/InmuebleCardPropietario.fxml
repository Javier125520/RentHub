<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.renthub.controller.CardInmueblePropietarioController"
      styleClass="card"
      spacing="10"
      prefWidth="300">

    <StackPane>
        <ImageView fx:id="imagen"
                   fitWidth="300"
                   fitHeight="180"
                   preserveRatio="false"
                   styleClass="card-image"/>

        <Button text="❮"
                onAction="#imagenAnterior"
                styleClass="carousel-btn left"
                StackPane.alignment="CENTER_LEFT"/>

        <Button text="❯"
                onAction="#imagenSiguiente"
                styleClass="carousel-btn right"
                StackPane.alignment="CENTER_RIGHT"/>
    </StackPane>

    <VBox spacing="6">
        <padding>
            <Insets top="12" right="12" bottom="12" left="12"/>
        </padding>

        <HBox>
            <Label fx:id="lblTitulo" styleClass="card-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblPrecio" styleClass="badge"/>
        </HBox>

        <Label fx:id="lblDireccion" styleClass="card-location"/>

        <Label fx:id="blbCiudad" styleClass="card-location"/>

        <Label fx:id="lblTipo" styleClass="tag"/>
        <Label fx:id="lblDescripcion" wrapText="true" styleClass="card-desc"/>

        <HBox spacing="10">
            <Label fx:id="habitaciones"/>
            <Label fx:id="huespedes"/>
        </HBox>

        <HBox spacing="10">
            <Button text="✏ Editar" styleClass="btn-outline" onAction="#onEditar"/>
            <Button text="🗑" styleClass="btn-danger" onAction="#onEliminar"/>
        </HBox>

    </VBox>
</VBox>
