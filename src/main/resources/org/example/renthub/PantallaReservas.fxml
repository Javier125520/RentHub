<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.ReservasController"
            stylesheets="@css/styles.css">

    <!-- =================== TOP BAR =================== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="topbar">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Button text="← Volver"
                    onAction="#volver"
                    styleClass="btn-secondary"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Label text="Reservas de Mis Inmuebles"
                   styleClass="main-title-small"/>
        </HBox>
    </top>


    <!-- =================== CONTENIDO =================== -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
            <VBox alignment="TOP_CENTER" spacing="25">
                <padding>
                    <Insets top="25" right="25" bottom="25" left="25"/>
                </padding>

                <!-- TITULO SECCION -->
                <Label text="Listado de Reservas"
                       styleClass="main-title"/>

                <!-- CONTENEDOR PRINCIPAL -->
                <VBox fx:id="contenedorReservas"
                      spacing="15"
                      maxWidth="950">
                    <!-- Aquí se insertan las tarjetas dinámicamente -->
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>

