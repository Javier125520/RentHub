<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.EditarPerfilController"
            stylesheets="@css/styles.css">

    <!-- =============== TOPBAR =============== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="topbar">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Button text="← Volver" onAction="#volver" styleClass="btn-secondary"/>

            <Pane HBox.hgrow="ALWAYS"/>
            <Label text="Editar Perfil" styleClass="main-title-small"/>
        </HBox>
    </top>

    <!-- =============== CONTENIDO =============== -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
            <VBox alignment="TOP_CENTER" spacing="35">
                <padding>
                    <Insets top="40" right="20" bottom="40" left="20"/>
                </padding>

                <!-- FOTO DE PERFIL -->
                <VBox alignment="CENTER" spacing="10">
                    <ImageView fx:id="imgPerfil"
                               fitWidth="150"
                               fitHeight="150"
                               preserveRatio="true"
                               smooth="true"
                               style="-fx-background-radius: 75; -fx-border-radius: 75;"/>

                    <Button text="Cambiar foto"
                            onAction="#cambiarFoto"
                            styleClass="btn-secondary"/>
                </VBox>

                <!-- FORMULARIO -->
                <VBox spacing="20" maxWidth="450">

                    <!-- NOMBRE -->
                    <VBox spacing="5">
                        <Label text="Nombre completo" styleClass="form-label"/>
                        <TextField fx:id="txtNombre" promptText="Introduce tu nombre completo"/>
                    </VBox>

                    <!-- EMAIL -->
                    <VBox spacing="5">
                        <Label text="Correo electrónico" styleClass="form-label"/>
                        <TextField fx:id="txtEmail" promptText="usuario@email.com"/>
                    </VBox>

                    <!-- TELÉFONO -->
                    <VBox spacing="5">
                        <Label text="Teléfono" styleClass="form-label"/>
                        <TextField fx:id="txtTelefono" promptText="+34 600 123 456"/>
                    </VBox>

                    <!-- CAMBIAR CONTRASEÑA -->
                    <VBox spacing="5">
                        <Label text="Contraseña" styleClass="form-label"/>
                        <Button text="Cambiar contraseña"
                                onAction="#cambiarContrasena"
                                styleClass="btn-secondary"
                                prefWidth="180"/>
                    </VBox>

                    <!-- GUARDAR -->
                    <HBox alignment="CENTER">
                        <Button text="Guardar cambios"
                                onAction="#guardar"
                                styleClass="btn-primary"
                                prefWidth="220"
                                prefHeight="45"/>
                    </HBox>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
