<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.ReservarInmuebleController"
            prefWidth="1200" prefHeight="800"
            stylesheets="@css/generales.css, @css/huesped.css">

    <!-- ─────────────────────────────────────────────── -->
    <!-- BARRA SUPERIOR                                  -->
    <!-- ─────────────────────────────────────────────── -->
    <top>
        <HBox spacing="15" style="-fx-background-color: #FFFFFF;" alignment="CENTER_LEFT">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Button text="⟵ Volver"
                    onAction="#volver"
                    styleClass="btn-secondary"/>

            <Label text="Reservar Inmueble"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
        </HBox>
    </top>


    <!-- ─────────────────────────────────────────────── -->
    <!-- CONTENIDO PRINCIPAL                             -->
    <!-- ─────────────────────────────────────────────── -->

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="40">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30"/>
                </padding>

                <!-- ▬▬▬▬▬▬▬ RESUMEN DEL INMUEBLE ▬▬▬▬▬▬▬ -->
                <HBox spacing="30">

                    <!-- Imagen -->
                    <ImageView fx:id="imgInmueble"
                               fitWidth="350" fitHeight="230"
                               preserveRatio="false"
                               style="-fx-background-radius: 12;" />

                    <!-- Información -->
                    <VBox spacing="10">
                        <Label fx:id="lblTitulo"
                               style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

                        <Label fx:id="lblCiudad"
                               style="-fx-text-fill: #636E72; -fx-font-size: 15px;"/>

                        <Label fx:id="lblDireccion"
                               style="-fx-text-fill: #636E72;"/>

                        <Label fx:id="lblPrecioNoche"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1B4F72;"/>

                    </VBox>

                </HBox>


                <!-- ▬▬▬▬▬▬▬ SELECCIÓN DE FECHAS ▬▬▬▬▬▬▬ -->
                <VBox spacing="10">
                    <Label text="Seleccionar fechas"
                           styleClass="subtitle"/>

                    <HBox spacing="40">

                        <VBox spacing="5">
                            <Label text="Fecha de entrada:"/>
                            <DatePicker fx:id="fechaInicio"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Fecha de salida:"/>
                            <DatePicker fx:id="fechaFin"/>
                        </VBox>

                    </HBox>

                </VBox>


                <!-- ▬▬▬▬▬▬▬ RESUMEN DEL PRECIO ▬▬▬▬▬▬▬ -->
                <VBox spacing="10">
                    <Label text="Resumen del precio"
                           styleClass="subtitle"/>

                    <VBox styleClass="card" spacing="15">

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Precio por noche:"/>
                            <Label fx:id="lblPrecioUnitario"/>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Noches:"/>
                            <Label fx:id="lblNoches"/>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Total:" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblPrecioTotal"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1B4F72;"/>
                        </HBox>

                    </VBox>
                </VBox>


                <!-- ▬▬▬▬▬▬▬ BOTÓN FINAL ▬▬▬▬▬▬▬ -->
                <HBox alignment="CENTER">
                    <padding>
                        <Insets top="40" right="0" bottom="40" left="0"/>
                    </padding>
                    <Button text="Confirmar Reserva"
                            styleClass="btn-primary"
                            prefWidth="350"
                            onAction="#confirmarReserva"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>


