<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.MisInmueblesController"
            prefWidth="1200" prefHeight="800"
            stylesheets="@css/generales.css, @css/propietario.css">

    <!-- ─────────────────────────────── -->
    <!-- BARRA SUPERIOR                  -->
    <!-- ─────────────────────────────── -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: #FFFFFF;">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Button text="⟵ Volver"
                    onAction="#volver"
                    styleClass="btn-secondary"/>

            <Label text="Mis Inmuebles"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <!-- BUSCADOR -->
            <TextField fx:id="txtBuscar"
                       promptText="Buscar inmueble..."
                       prefWidth="250"
                       styleClass="search-bar"/>

            <!-- BOTÓN NUEVO INMUEBLE -->
            <Button text="➕ Nuevo"
                    styleClass="btn-primary"
                    onAction="#crearInmueble"/>
        </HBox>
    </top>



    <!-- ─────────────────────────────── -->
    <!-- CONTENIDO                       -->
    <!-- ─────────────────────────────── -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="25" alignment="TOP_CENTER">
                <padding>
                    <Insets top="25" right="25" bottom="25" left="25"/>
                </padding>

                <!-- CONTENEDOR DE CARDS -->
                <FlowPane fx:id="contenedorInmuebles"
                          hgap="25" vgap="25"
                          alignment="CENTER"
                          prefWidth="1100"
                          style="-fx-padding: 10;">
                </FlowPane>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>

