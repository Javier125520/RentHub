<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.DetallesReservaController"
            stylesheets="@css/styles.css">

    <!-- =============== TOPBAR =============== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="topbar">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Button text="← Volver" onAction="#volver" styleClass="btn-secondary"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Label text="Detalles de la Reserva" styleClass="main-title-small"/>
        </HBox>
    </top>


    <!-- =============== CONTENIDO PRINCIPAL =============== -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
            <VBox alignment="TOP_CENTER" spacing="35">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30"/>
                </padding>

                <!-- FOTO PRINCIPAL -->
                <ImageView fx:id="imgPrincipal"
                           fitWidth="850"
                           fitHeight="450"
                           preserveRatio="true"
                           smooth="true"
                           style="-fx-background-radius: 15;"/>

                <!-- INFORMACIÓN DEL INMUEBLE -->
                <VBox spacing="10" maxWidth="850" alignment="TOP_LEFT">

                    <Label fx:id="lblTitulo" text="Apartamento en Madrid"
                           styleClass="main-title"/>

                    <Label fx:id="lblUbicacion" text="📍 Madrid, España"
                           styleClass="subtitle"/>

                </VBox>

                <!-- INFORMACIÓN DE LA RESERVA -->
                <VBox spacing="20" maxWidth="850">

                    <!-- Fechas -->
                    <VBox spacing="10">
                        <Label text="Fechas" styleClass="main-title-small"/>
                        <Label fx:id="lblFechas"
                               text="📅 12/12/2025 → 15/12/2025"
                               style="-fx-font-size: 16px; -fx-text-fill: #cbd5e0;"/>
                    </VBox>

                    <!-- Huespedes -->
                    <VBox spacing="10">
                        <Label text="Huéspedes" styleClass="main-title-small"/>
                        <Label fx:id="lblHuespedes"
                               text="👤 2 huéspedes"
                               style="-fx-font-size: 16px; -fx-text-fill: #cbd5e0;"/>
                    </VBox>

                    <!-- Precio -->
                    <VBox spacing="10">
                        <Label text="Precio" styleClass="main-title-small"/>

                        <VBox spacing="5">
                            <Label fx:id="lblPrecioNoche"
                                   text="95 €/noche"
                                   styleClass="card-sub"/>

                            <Label fx:id="lblNoches"
                                   text="3 noches"
                                   styleClass="card-sub"/>

                            <Label fx:id="lblTotal"
                                   text="285 €"
                                   styleClass="card-price"/>
                        </VBox>
                    </VBox>

                    <!-- ESTADO -->
                    <VBox spacing="10">
                        <Label text="Estado" styleClass="main-title-small"/>
                        <Label fx:id="lblEstado"
                               text="Confirmada"
                               style="-fx-font-size: 17px; -fx-text-fill: #4fd664; -fx-font-weight: bold;"/>
                    </VBox>

                    <!-- BOTÓN CANCELAR -->
                    <HBox alignment="CENTER">
                        <Button fx:id="btnCancelar"
                                text="Cancelar Reserva"
                                onAction="#cancelar"
                                styleClass="btn-danger"
                                prefWidth="250"
                                prefHeight="45"/>
                    </HBox>

                    <!-- BOTÓN DESCARGAR RECIBO -->
                    <HBox alignment="CENTER">
                        <Button fx:id="btnRecibo"
                                text="Descargar Recibo"
                                onAction="#descargarRecibo"
                                styleClass="btn-primary"
                                prefWidth="250"
                                prefHeight="45"/>
                    </HBox>


                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>

