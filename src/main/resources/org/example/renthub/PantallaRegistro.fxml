<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/17.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.renthub.controller.RegistroController"
      stylesheets="@css/styles.css">

    <VBox spacing="12" maxWidth="380" styleClass="card" alignment="TOP_CENTER">
        <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

        <Label text="🏠" style="-fx-font-size: 35; -fx-text-fill: #2563EB;"/>
        <Label text="RentHub" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
        <Label text="Plataforma de alquiler de viviendas" style="-fx-text-fill: #6B7280;"/>

        <HBox alignment="CENTER" style="-fx-background-color: #F3F4F6; -fx-background-radius: 20;">
            <Button text="Iniciar Sesión" onAction="#IrAInicioSesion" style="-fx-background-color: transparent;" prefWidth="140"/>
            <Button text="Crear Cuenta" style="-fx-background-color: white; -fx-background-radius: 20;" prefWidth="140"/>
        </HBox>

        <VBox alignment="CENTER_LEFT" spacing="5">
            <Label text="Nombre completo" style="-fx-font-weight: bold;"/>
            <TextField fx:id="nombreField" promptText="Juan Pérez"/>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="5">
            <Label text="Email" style="-fx-font-weight: bold;"/>
            <TextField fx:id="emailField" promptText="tu@email.com"/>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="5">
            <Label text="Contraseña" style="-fx-font-weight: bold;"/>
            <PasswordField fx:id="passwordField" promptText="********"/>
        </VBox>

        <VBox spacing="15">
            <fx:define>
                <ToggleGroup fx:id="roleGroup"/>
            </fx:define>

            <Label text="Tipo de cuenta" style="-fx-font-weight: bold;"/>

            <RadioButton toggleGroup="$roleGroup" fx:id="rbHuesped" maxWidth="Infinity" selected="true" styleClass="radio-button">
                <graphic>
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="👤" style="-fx-font-size: 20;"/>
                        <VBox>
                            <Label text="Huésped" styleClass="rol-titulo"/>
                            <Label text="Busca y reserva viviendas" styleClass="rol-descripcion"/>
                        </VBox>
                    </HBox>
                </graphic>
            </RadioButton>

            <RadioButton toggleGroup="$roleGroup" fx:id="rbPropietario" maxWidth="Infinity" styleClass="radio-button">
                <graphic>
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="🏠" style="-fx-font-size: 20;"/>
                        <VBox>
                            <Label text="Propietario" styleClass="rol-titulo"/>
                            <Label text="Publica y gestiona viviendas" styleClass="rol-descripcion"/>
                        </VBox>
                    </HBox>
                </graphic>
            </RadioButton>
        </VBox>

        <Button text="Crear Cuenta" onAction="#onRegistrar" styleClass="button-primary" maxWidth="Infinity" prefHeight="40"/>
    </VBox>
</VBox>

