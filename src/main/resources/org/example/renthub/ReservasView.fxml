<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.renthub.controller.ReservasViewController"
      spacing="25"
      styleClass="content">

    <!-- TÍTULO -->
    <VBox spacing="5">
        <Label text="Reservas de Mis Viviendas" styleClass="title"/>
        <Label text="Reservas realizadas en tus propiedades" styleClass="description"/>
    </VBox>

    <!-- LISTA DE RESERVAS -->
    <VBox fx:id="reservasContainer" spacing="20"/>

    <!-- RESUMEN -->
    <VBox styleClass="income-summary" spacing="8">
        <Label text="Resumen de Ingresos" styleClass="income-title"/>
        <Label fx:id="lblTotalIngresos" text="€0" styleClass="income-total"/>
        <Label fx:id="lblTotalReservas" text="Total de reservas pagadas: 0" styleClass="income-sub"/>
    </VBox>

</VBox>

