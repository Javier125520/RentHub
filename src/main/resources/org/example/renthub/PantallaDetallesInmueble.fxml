<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.renthub.controller.DetallesInmuebleController"
            stylesheets="@css/styles.css">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="topbar">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Button text="← Volver" onAction="#volver" styleClass="btn-secondary"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Label text="Detalle del Inmueble" styleClass="main-title-small"/>
        </HBox>
    </top>

    <!-- ================= CONTENIDO ================= -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
            <VBox spacing="30" alignment="TOP_CENTER">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <!-- FOTO PRINCIPAL -->
                <ImageView fx:id="imgPrincipal"
                           fitWidth="900"
                           fitHeight="500"
                           preserveRatio="true"
                           smooth="true"
                           style="-fx-background-radius: 20;"/>

                <!-- TITULO + UBICACION + PRECIO -->
                <VBox spacing="10" alignment="TOP_LEFT" maxWidth="900">

                    <Label fx:id="lblTitulo" text="Título del Inmueble"
                           styleClass="main-title"/>

                    <Label fx:id="lblUbicacion" text="Madrid, España"
                           styleClass="subtitle"/>

                    <Label fx:id="lblPrecio" text="95 €/noche"
                           styleClass="card-price"/>

                </VBox>

                <!-- GALERÍA -->
                <HBox fx:id="galeria" spacing="15" maxWidth="900"/>

                <!-- SERVICIOS -->
                <VBox spacing="10" maxWidth="900">
                    <Label text="Servicios incluidos" styleClass="main-title-small"/>

                    <FlowPane fx:id="listaServicios"
                              hgap="10" vgap="10"
                              maxWidth="900"/>
                </VBox>

                <!-- DESCRIPCIÓN -->
                <VBox spacing="10" maxWidth="900">
                    <Label text="Descripción" styleClass="main-title-small"/>

                    <Label fx:id="lblDescripcion"
                           wrapText="true"
                           style="-fx-font-size: 16px; -fx-text-fill: #cbd5e0;"/>
                </VBox>

                <!-- BOTÓN RESERVAR -->
                <HBox alignment="CENTER" maxWidth="900">
                    <Button text="Reservar ahora"
                            onAction="#reservar"
                            styleClass="btn-primary"
                            prefWidth="250"
                            prefHeight="45"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>

